# mkcd: create directory (including parents) and cd into it
function mkcd() {
    mkdir -p "$1" && cd "$1"
}

# fkill: fuzzy-find and kill a process
function fkill() {
    local pid
    pid=$(ps -ef | sed 1d | fzf -m --header='Select process to kill' | awk '{print $2}')
    if [ -n "$pid" ]; then
        echo "$pid" | xargs kill -${1:-9}
        echo "Killed PID(s): $pid"
    fi
}

# fenv: fuzzy search environment variables
function fenv() {
    env | sort | fzf --preview 'echo {}'
}

# fcd: fuzzy cd into any subdirectory (uses fd if available)
function fcd() {
    local dir preview_cmd
    if command -v tree &>/dev/null; then
        preview_cmd='tree -C {} | head -30'
    else
        preview_cmd='ls {}'
    fi
    if command -v fd &>/dev/null; then
        dir=$(fd --type d --hidden --follow --exclude .git 2>/dev/null | fzf --preview "$preview_cmd")
    else
        dir=$(find . -type d 2>/dev/null | fzf --preview 'ls {}')
    fi
    [ -n "$dir" ] && cd "$dir"
}

# fshow: fuzzy git log browser with diff preview
function fshow() {
    git log --graph --color=always \
        --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" |
    fzf --ansi --no-sort --reverse \
        --preview 'grep -o "[a-f0-9]\{7,\}" <<< {} | head -1 | xargs git show --color=always' \
        --bind "enter:execute(grep -o '[a-f0-9]\{7,\}' <<< {} | head -1 | xargs git show --color=always | less -R)"
}

# port: show what is listening on a given port
function port() {
    lsof -i :"$1"
}

# extract: universal archive extractor
function extract() {
    case "$1" in
        *.tar.bz2)  tar xjf "$1"     ;;
        *.tar.gz)   tar xzf "$1"     ;;
        *.tar.xz)   tar xJf "$1"     ;;
        *.tar)      tar xf  "$1"     ;;
        *.zip)      unzip   "$1"     ;;
        *.gz)       gunzip  "$1"     ;;
        *.bz2)      bunzip2 "$1"     ;;
        *.7z)       7z x    "$1"     ;;
        *)          echo "Don't know how to extract '$1'" ;;
    esac
}

# y: yazi file manager that cds to last directory on exit
function y() {
    local tmp cwd
    tmp="$(mktemp -t "yazi-cwd.XXXXX")"
    yazi "$@" --cwd-file="$tmp"
    cwd="$(cat -- "$tmp")"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
}

# frg: search file contents with ripgrep, preview matches, open in editor
function frg() {
    local result file line
    result=$(rg --color=always --line-number --no-heading --smart-case "${*:-}" |
        fzf --ansi --delimiter=: \
            --preview 'bat --style=numbers --color=always --highlight-line {2} {1}' \
            --preview-window=right:60%:+{2}+3/3)
    [ -n "$result" ] && {
        file=$(echo "$result" | cut -d: -f1)
        line=$(echo "$result" | cut -d: -f2)
        nvim +"$line" "$file"
    }
}

# gco: fuzzy git branch checkout
function gco() {
    local branch
    branch=$(git branch -a --color=always | grep -v '/HEAD\s' | sort |
        fzf --ansi --tac --preview 'git log --oneline --color=always $(echo {} | sed "s/.* //")' |
        sed 's/.* //' | sed 's#remotes/[^/]*/##')
    [ -n "$branch" ] && git checkout "$branch"
}

# fo: fuzzy file open in editor (filename search, pairs with frg for content search)
function fo() {
    local file
    file=$(fd --type f --hidden --follow --exclude .git |
        fzf --preview 'bat --style=numbers --color=always --line-range=:100 {}')
    [ -n "$file" ] && nvim "$file"
}

# fstash: fuzzy git stash browser — preview diff and pop selected stash
function fstash() {
    local stash
    stash=$(git stash list |
        fzf --preview 'git stash show -p $(echo {} | cut -d: -f1) --color=always' |
        cut -d: -f1)
    [ -n "$stash" ] && git stash pop "$stash"
}

# fssh: fuzzy SSH host picker from ~/.ssh/config
function fssh() {
    local host
    host=$(grep "^Host " ~/.ssh/config 2>/dev/null | grep -v '\*' | awk '{print $2}' |
        fzf --preview 'grep -A5 "^Host {}$" ~/.ssh/config')
    [ -n "$host" ] && ssh "$host"
}

# _cli_tip: show one rotating practice prompt per day at shell startup
function _cli_tip() {
    local tips=(
        "Practice: find a file with ctrl+t instead of typing the path"
        "Practice: use 'z <partial>' to jump somewhere you've been before"
        "Practice: search inside files with 'frg <term>' and open at the match"
        "Practice: browse with 'y' — navigate, then quit to land in that dir"
        "Practice: fuzzy checkout a branch with 'gco' instead of 'git checkout'"
        "Practice: kill a process with 'fkill' instead of 'ps aux | grep'"
        "Practice: use 'zi' for interactive zoxide — faster than fcd for known dirs"
        "Practice: ctrl+r for history — try recalling a command from last week"
        "Practice: open a file by name with 'fo' instead of typing the path"
        "Practice: browse and pop a git stash with 'fstash'"
        "Practice: connect to a server with 'fssh' instead of typing the host"
    )
    local idx=$(( ($(date +%j) % ${#tips[@]}) + 1 ))  # 1-based for zsh arrays
    printf '\e[2m[tip] %s\e[0m\n' "${tips[$idx]}"
}

# ccds: invoke claude with DeepSeek endpoint
function ccds() {
    ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic \
    ANTHROPIC_AUTH_TOKEN="$DEEPSEEK_API_KEY" \
    ANTHROPIC_MODEL="deepseek-v4-pro[1m]" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek-v4-pro[1m]" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-v4-pro[1m]" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="deepseek-v4-flash" \
    CLAUDE_CODE_SUBAGENT_MODEL="deepseek-v4-flash" \
    CLAUDE_CODE_EFFORT_LEVEL="max" \
    claude "$@"
}
