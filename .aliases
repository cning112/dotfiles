# --------------------------------------------------------
# General Aliases
# --------------------------------------------------------
alias l="ls"
alias ll="ls -alh"
alias vi="nvim"
alias awslocal="uvx --from awscli-local awslocal"
alias h="history | fzf"

# bat: better cat with syntax highlighting
if command -v bat &>/dev/null; then
    alias cat="bat --paging=never"
    alias less="bat"
fi

# zoxide provides 'z' and 'zi' natively after init in .tools
# Optionally replace 'cd' entirely: change zoxide init to --cmd cd in .tools

# Open current directory (platform-aware)
if $IS_MACOS; then
    alias o="open ."
elif $IS_WSL; then
    alias o="wslview ."
else
    alias o="xdg-open ."
fi


# --------------------------------------------------------
# Git Aliases
# --------------------------------------------------------
alias gaa='git add .'
alias gcm='git commit -m'
alias gpsh='git push'
alias gss='git status -s'
alias gs='echo ""; echo "*********************************************"; echo -e "   DO NOT FORGET TO PULL BEFORE COMMITTING"; echo "*********************************************"; echo ""; git status'


# --------------------------------------------------------
# macOS only
# --------------------------------------------------------
if $IS_MACOS; then
    alias icloud="cd ~/Library/Mobile\ Documents/com~apple~CloudDocs"
fi
