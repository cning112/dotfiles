" IdeaVim 专用配置

" 加载通用配置文件
source ~/.common_vimrc

" Refer to https://gist.github.com/AlexPl292/50a3ff4cef1badcbb23436b22cbd3cf4
""" Plugins  --------------------------------
set easymotion
set surround
set multiple-cursors
set commentary
set argtextobj
set textobj-entire
set ReplaceWithRegister
set exchange
set highlightedyank

""" Plugin settings -------------------------
let g:argtextobj_pairs="[:],(:),<:>"

""" Idea specific settings ------------------
set ideajoin
set ideastatusicon=gray

" All modes delegated to the IDE — Vim motion keys (n/w/b etc.) are overridden
" by IDE shortcuts. Remove this line to restore Vim key handling.
sethandler i:ide n:ide v:ide

" Override .common_vimrc's scrolloff=5; keep cursor at edge in IDE
set scrolloff=0
