[user]
	name = Chao Ning
	email = chao.ning.uk@gmail.com
[core]
	editor = nvim
	autocrlf = input
	pager = delta

[init]
	defaultBranch = main

[alias]
# credit to https://stackoverflow.com/a/9074343/15853959
lg1 = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all
lg2 = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(auto)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'
lg = lg1

# credit to https://stackoverflow.com/a/35075021/15853959
adog = log --all --decorate --oneline --graph

# Undo last commit, keep changes staged
undo = reset --soft HEAD~1

# Show files changed in last commit
last = diff HEAD~1 HEAD --name-only

[delta]
	navigate = true      # use n/N to move between diff sections
	side-by-side = true
	line-numbers = true
	syntax-theme = Dracula

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[credential]
	# Empty entry clears system default before setting GCM
	helper =
	helper = /usr/local/share/gcm-core/git-credential-manager

[credential "https://dev.azure.com"]
	useHttpPath = true
